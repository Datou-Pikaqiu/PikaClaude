# PikaClaude 环境配置模板
# 用法：cp .env.example .env，然后按需修改

# ── Core Daemon ───────────────────────────────────────────────
Pika_HOST=127.0.0.1
Pika_PORT=7437

# ── Logging ───────────────────────────────────────────────────
Pika_LOG_LEVEL=INFO
# 留空则仅输出 stderr，不写文件
Pika_LOG_FILE=~/.Pika/logs/core.log
# text（人工可读键值对）或 json（结构化，适合日志聚合）
Pika_LOG_FORMAT=text

# ── Config File ───────────────────────────────────────────────
# Pika_CONFIG=~/.Pika/config.toml

# ── LLM（S1 阶段启用）────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# Pika_LLM_MODEL=claude-sonnet-4-6
# Pika_MAX_STEPS=20